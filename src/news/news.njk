---
layout: base.njk
pageTitle: お知らせ
permalink: /news/index.html
---
<main class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-kon mb-6 border-l-4 border-midori pl-3">お知らせ</h1>
  <ul class="space-y-4">
    {% for item in collections.news %}
    <li class="border-b pb-4">
      <time class="text-sm text-gray-500">{{ item.date | dateJp }}</time>
      <a href="{{ item.url }}" class="block text-base mt-1 hover:underline text-kon">{{ item.data.title }}</a>
      {% if item.data.thumbnail %}
      <img src="{{ item.data.thumbnail }}" alt="{{ item.data.title }}" class="mt-2 rounded w-full max-h-40 object-cover">
      {% endif %}
    </li>
    {% else %}
    <li class="text-gray-500">お知らせはまだありません。</li>
    {% endfor %}
  </ul>
</main>
