---
layout: base.njk
pageTitle: トップ
permalink: /index.html
---

<!-- ヒーローセクション -->
<section class="relative">
  <img src="/assets/images/hero_spring.png" alt="甲子園町の春の風景" class="w-full object-cover">
  <div class="absolute inset-0 bg-black/10 flex flex-col items-center justify-center text-white text-center px-4">
    <p class="text-xl md:text-3xl font-bold leading-relaxed drop-shadow">
      甲子園球場のそばで、<br>つながりつづけるまち。
    </p>
    <p class="mt-2 text-sm md:text-base drop-shadow">思わず自慢したくなる街</p>
  </div>
</section>

<!-- クイックメニュー -->
<section class="bg-gray-50 border-b">
  <div class="max-w-2xl mx-auto px-4 py-4 grid grid-cols-4 gap-2 text-center">
    <a href="/news/" class="flex flex-col items-center gap-1 py-2 rounded-lg hover:bg-gray-100">
      <span class="text-2xl">📢</span>
      <span class="text-xs text-gray-700">お知らせ</span>
    </a>
    <a href="/events/" class="flex flex-col items-center gap-1 py-2 rounded-lg hover:bg-gray-100">
      <span class="text-2xl">📅</span>
      <span class="text-xs text-gray-700">イベント</span>
    </a>
    <a href="/reserve/" class="flex flex-col items-center gap-1 py-2 rounded-lg hover:bg-gray-100">
      <span class="text-2xl">🏠</span>
      <span class="text-xs text-gray-700">会館予約</span>
    </a>
    <a href="/contact/" class="flex flex-col items-center gap-1 py-2 rounded-lg hover:bg-gray-100">
      <span class="text-2xl">✉️</span>
      <span class="text-xs text-gray-700">お問い合わせ</span>
    </a>
  </div>
</section>

<main class="max-w-2xl mx-auto px-4 py-6 space-y-8">

  <!-- 最新情報 -->
  <section>
    <h2 class="text-lg font-bold text-kon border-l-4 border-midori pl-3 mb-4">最新情報</h2>
    <ul class="space-y-3">
      {% for item in collections.updates | limit(3) %}
      <li class="flex gap-3 border-b pb-3">
        <time class="text-sm text-gray-500 whitespace-nowrap">{{ item.date | dateJp }}</time>
        <a href="{{ item.url }}" class="text-base hover:underline text-kon">{{ item.data.title }}</a>
      </li>
      {% else %}
      <li class="text-gray-500 text-sm">情報はまだありません。</li>
      {% endfor %}
    </ul>
    <div class="mt-3 text-right">
      <a href="/news/" class="text-sm text-midori hover:underline">お知らせ一覧 →</a>
    </div>
  </section>

  <!-- 最新の回覧板 -->
  <section class="bg-green-50 rounded-lg p-4">
    <h2 class="text-lg font-bold text-kon border-l-4 border-midori pl-3 mb-3">最新の回覧板</h2>
    <div class="flex items-center justify-between">
      <span class="text-base">2026年3月号</span>
      <a href="#" class="inline-flex items-center gap-1 bg-midori text-white text-sm px-4 py-2 rounded-lg hover:opacity-90">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        PDFを見る
      </a>
    </div>
  </section>

  <!-- 会館予約CTA -->
  <section class="text-center">
    <a href="/reserve/" class="inline-flex items-center gap-2 bg-midori text-white text-lg font-bold px-8 py-4 rounded-xl shadow hover:opacity-90 w-full justify-center">
      🏠 月見里会館を予約する
    </a>
  </section>

</main>
