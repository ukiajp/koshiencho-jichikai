---
layout: base.njk
---
<main class="max-w-2xl mx-auto px-4 py-8">
  <a href="/activities/" class="text-sm text-midori hover:underline">← 活動報告一覧に戻る</a>
  <article class="mt-4">
    <div class="flex items-center gap-2 mb-2">
      {% if group == "hana" %}<span class="bg-green-100 text-green-800 text-xs px-2 py-0.5 rounded-full font-bold">花の会</span>
      {% elif group == "tokiwa" %}<span class="bg-blue-100 text-blue-800 text-xs px-2 py-0.5 rounded-full font-bold">ときわ会</span>
      {% elif group == "hibari" %}<span class="bg-pink-100 text-pink-800 text-xs px-2 py-0.5 rounded-full font-bold">ひばり会</span>
      {% elif group == "bohan" %}<span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-0.5 rounded-full font-bold">防犯部</span>
      {% endif %}
      <time class="text-sm text-gray-500">{{ date | dateJp }}</time>
    </div>
    <h1 class="text-2xl font-bold text-kon mb-6 border-l-4 border-midori pl-3">{{ title }}</h1>
    {% if thumbnail %}
    <img src="{{ thumbnail }}" alt="{{ title }}" class="w-full rounded-lg mb-6 object-cover max-h-64">
    {% endif %}
    <div class="prose prose-sm max-w-none text-gray-700 leading-relaxed space-y-4">
      {{ content | safe }}
    </div>
  </article>
</main>
